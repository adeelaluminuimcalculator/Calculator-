<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bathroom Door Calculator - Adeel Welding & Aluminium House</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --dark: #0f1015;
    --dark2: #1a1d24;
    --dark3: #22262f;
    --border: #2e3340;
    --text: #e8e8e8;
    --muted: #7a8090;
    --accent: #4a9eff;
    --green: #3ddc97;
    --red: #ff6b6b;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
  }

  .header {
    background: linear-gradient(135deg, #1a1d24 0%, #0d1520 100%);
    border-bottom: 2px solid var(--gold);
    padding: 18px 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 4px 30px rgba(0,0,0,0.5);
  }

  .logo-area { display: flex; align-items: center; gap: 16px; }

  .logo-icon {
    width: 56px; height: 56px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; font-weight: 900;
    color: var(--dark);
    font-family: 'Playfair Display', serif;
    box-shadow: 0 0 20px rgba(201,168,76,0.4);
  }

  .logo-text h1 {
    font-family: 'Playfair Display', serif;
    font-size: 18px; font-weight: 900;
    color: var(--gold);
    text-transform: uppercase; letter-spacing: 1px;
  }

  .logo-text p { font-size: 12px; color: var(--muted); letter-spacing: 1px; }

  .header-right { text-align: right; }
  .header-right strong { color: var(--gold); font-size: 15px; display: block; }
  .header-right span { font-size: 12px; color: var(--muted); }

  .container { max-width: 900px; margin: 0 auto; padding: 30px 20px; }

  /* PAGE TITLE */
  .page-title {
    text-align: center;
    margin-bottom: 28px;
  }
  .page-title h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 3px;
  }
  .page-title p { color: var(--muted); font-size: 13px; margin-top: 4px; }

  .card {
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 15px; font-weight: 700;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex; align-items: center; gap: 10px;
    text-transform: uppercase; letter-spacing: 1px;
  }

  .badge {
    background: var(--gold); color: var(--dark);
    font-size: 10px; padding: 2px 8px;
    border-radius: 20px;
    font-family: 'DM Sans', sans-serif; font-weight: 700;
  }

  .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }

  .form-group { display: flex; flex-direction: column; gap: 6px; }

  label {
    font-size: 11px; font-weight: 600;
    color: var(--muted);
    text-transform: uppercase; letter-spacing: 1px;
  }

  input[type="number"] {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-size: 16px;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    width: 100%;
  }

  input[type="number"]:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
    background: #1e2230;
  }

  input::placeholder { color: var(--muted); }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 8px;
  }

  .result-grid.three { grid-template-columns: repeat(3, 1fr); }

  .rbox {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 10px;
    text-align: center;
  }

  .rbox .rl { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; }
  .rbox .rv { font-size: 13px; font-weight: 600; color: var(--gold-light); }
  .rbox .rs { font-size: 10px; color: var(--muted); margin-top: 3px; }

  .info-box {
    background: rgba(74,158,255,0.08);
    border: 1px solid rgba(74,158,255,0.2);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 12px; color: var(--accent);
    margin-top: 12px;
    line-height: 1.8;
  }

  .sqft-bar {
    background: linear-gradient(135deg, #1a2035, #0f1520);
    border: 1px solid var(--accent);
    border-radius: 12px;
    padding: 16px 20px;
    text-align: center;
    margin-bottom: 20px;
    display: flex; align-items: center; justify-content: center; gap: 20px;
  }

  .sqft-bar .sq-item { text-align: center; }
  .sqft-bar .sq-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
  .sqft-bar .sq-val { font-size: 22px; font-weight: 700; color: var(--accent); font-family: 'Playfair Display', serif; }

  .extra-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

  .extra-box {
    background: var(--dark3);
    border: 1px dashed var(--border);
    border-radius: 12px;
    padding: 16px;
  }

  .summary-card {
    background: linear-gradient(135deg, #1a2035, #0f1520);
    border: 2px solid var(--gold);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 20px;
    box-shadow: 0 0 40px rgba(201,168,76,0.1);
  }

  .summary-title {
    font-family: 'Playfair Display', serif;
    font-size: 17px; color: var(--gold);
    margin-bottom: 20px;
    text-transform: uppercase; letter-spacing: 2px;
    text-align: center;
  }

  .sline {
    display: flex; justify-content: space-between; align-items: center;
    padding: 9px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
  }
  .sline:last-child { border-bottom: none; }
  .sline .sl { color: var(--muted); }
  .sline .sv { font-weight: 600; color: var(--text); }
  .sline.disc .sv { color: var(--red); }
  .sline.grand .sl { font-size: 16px; font-weight: 700; color: var(--gold); }
  .sline.grand .sv { font-size: 22px; font-weight: 700; color: var(--green); }

  .btn-print {
    width: 100%; padding: 16px;
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--dark); border: none; border-radius: 12px;
    font-size: 15px; font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer; letter-spacing: 2px; text-transform: uppercase;
    transition: all 0.2s; margin-bottom: 12px;
  }
  .btn-print:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(201,168,76,0.4); }

  .btn-reset {
    width: 100%; padding: 14px;
    background: transparent; color: var(--muted);
    border: 1px solid var(--border); border-radius: 12px;
    font-size: 14px; font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer; letter-spacing: 1px; text-transform: uppercase;
    transition: all 0.2s;
  }
  .btn-reset:hover { border-color: var(--red); color: var(--red); }

  @media print {
    body { background: #fff; color: #000; }
    .header { background: #fff; border-bottom: 2px solid #c9a84c; color: #000; }
    .logo-text h1 { color: #c9a84c; }
    .logo-text p, .header-right span { color: #555; }
    .header-right strong { color: #c9a84c; }
    .page-title h2 { color: #c9a84c; }
    .page-title p { color: #555; }
    .card { background: #f9f9f9; border: 1px solid #ddd; break-inside: avoid; }
    .card::before { display: none; }
    .card-title { color: #c9a84c; }
    .rbox { background: #f0f0f0; border: 1px solid #ddd; }
    .rbox .rl { color: #888; }
    .rbox .rv { color: #333; }
    .rbox .rs { color: #888; }
    .info-box { background: #e8f4ff; border: 1px solid #aad; color: #336; }
    .sqft-bar { background: #f0f5ff; border: 1px solid #99b; }
    .sqft-bar .sq-label { color: #555; }
    .sqft-bar .sq-val { color: #336; }
    .extra-box { background: #f0f0f0; border: 1px dashed #ccc; }
    input { background: #f0f0f0; color: #000; border: 1px solid #ccc; }
    label { color: #555; }
    .summary-card { background: #fffbe8; border: 2px solid #c9a84c; }
    .summary-title { color: #c9a84c; }
    .sline .sl { color: #555; }
    .sline .sv { color: #000; }
    .sline.disc .sv { color: #c00; }
    .sline.grand .sl { color: #c9a84c; }
    .sline.grand .sv { color: #060; }
    .sline { border-bottom: 1px solid #ddd; }
    .btn-print, .btn-reset { display: none; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="logo-area">
    <div class="logo-icon">A</div>
    <div class="logo-text">
      <h1>Adeel Welding & Aluminium House</h1>
      <p>Professional Aluminium Calculator</p>
    </div>
  </div>
  <div class="header-right">
    <strong>📞 03217378024</strong>
    <span>Aluminium & Fabrication</span>
  </div>
</div>

<div class="container">

  <div class="page-title">
    <h2>🚿 Bathroom Door Calculator</h2>
    <p>Size inches mein dalein — sab kuch automatic calculate hoga</p>
  </div>

  <!-- SIZE INPUT -->
  <div class="card">
    <div class="card-title">📐 Chughat Size <span class="badge">Inches mein</span></div>
    <div class="input-row">
      <div class="form-group">
        <label>Chughat Width (inches)</label>
        <input type="number" id="cw" placeholder="e.g. 30" oninput="calculate()">
      </div>
      <div class="form-group">
        <label>Chughat Height (inches)</label>
        <input type="number" id="ch" placeholder="e.g. 80" oninput="calculate()">
      </div>
    </div>
  </div>

  <!-- D54A -->
  <div class="card">
    <div class="card-title">🔲 D54A — Chughat Frame <span class="badge">Rate: 397/ft</span></div>
    <div class="result-grid">
      <div class="rbox">
        <div class="rl">Top (1 pc)</div>
        <div class="rv" id="d54a_top">0.00 ft</div>
        <div class="rs">Width</div>
      </div>
      <div class="rbox">
        <div class="rl">Sides (2 pcs)</div>
        <div class="rv" id="d54a_sides">0.00 ft</div>
        <div class="rs">Height × 2</div>
      </div>
      <div class="rbox">
        <div class="rl">Total Feet</div>
        <div class="rv" id="d54a_total">0.00 ft</div>
        <div class="rs">—</div>
      </div>
      <div class="rbox">
        <div class="rl">Amount</div>
        <div class="rv" id="d54a_amt">Rs. 0</div>
        <div class="rs">—</div>
      </div>
    </div>
  </div>

  <!-- D50A -->
  <div class="card">
    <div class="card-title">🚪 D50A — Door Frame <span class="badge">Rate: 490/ft</span></div>
    <div class="result-grid">
      <div class="rbox">
        <div class="rl">Top (1 pc)</div>
        <div class="rv" id="d50a_top">0.00 ft</div>
        <div class="rs">Width</div>
      </div>
      <div class="rbox">
        <div class="rl">Bottom (1 pc)</div>
        <div class="rv" id="d50a_bot">0.00 ft</div>
        <div class="rs">Width</div>
      </div>
      <div class="rbox">
        <div class="rl">Sides (2 pcs)</div>
        <div class="rv" id="d50a_sides">0.00 ft</div>
        <div class="rs">Height × 2</div>
      </div>
      <div class="rbox">
        <div class="rl">Amount</div>
        <div class="rv" id="d50a_amt">Rs. 0</div>
        <div class="rs">Rate: 490/ft</div>
      </div>
    </div>
    <div class="info-box">
      🔩 D52 (Mid Bar) — 1 piece = Width &nbsp;|&nbsp;
      Feet: <strong id="d52_ft">0.00 ft</strong> &nbsp;|&nbsp;
      Amount: <strong id="d52_amt">Rs. 0</strong> &nbsp;(Rate: 434/ft)
    </div>
  </div>

  <!-- D61 -->
  <div class="card">
    <div class="card-title">📋 D61 — Plate Section <span class="badge">Rate: 514/ft</span></div>
    <div class="result-grid">
      <div class="rbox">
        <div class="rl">Plate Lambai</div>
        <div class="rv" id="d61_lambai">0.0 in</div>
        <div class="rs">Width - 3"</div>
      </div>
      <div class="rbox">
        <div class="rl">Inner Height</div>
        <div class="rv" id="d61_inner">0.0 in</div>
        <div class="rs">Height - 4.5"</div>
      </div>
      <div class="rbox">
        <div class="rl">Qty (pcs)</div>
        <div class="rv" id="d61_qty">0 pcs</div>
        <div class="rs">÷ 87mm (3.425")</div>
      </div>
      <div class="rbox">
        <div class="rl">Amount</div>
        <div class="rv" id="d61_amt">Rs. 0</div>
        <div class="rs" id="d61_ft_show">0.00 ft</div>
      </div>
    </div>
  </div>

  <!-- SQFT -->
  <div class="sqft-bar">
    <div class="sq-item">
      <div class="sq-label">📏 Total Area</div>
      <div class="sq-val" id="sqft_val">0.00 sq.ft</div>
    </div>
  </div>

  <!-- EXTRAS -->
  <div class="card">
    <div class="card-title">⚙️ Extra Options</div>
    <div class="extra-grid">
      <div class="extra-box">
        <label>🏷️ Discount %</label>
        <input type="number" id="discount_pct" placeholder="e.g. 30" oninput="calculate()">
      </div>
      <div class="extra-box">
        <label>🔧 Labour (Rs.)</label>
        <input type="number" id="labour" placeholder="e.g. 5000" oninput="calculate()">
      </div>
      <div class="extra-box">
        <label>🔩 Accessories (Rs.)</label>
        <input type="number" id="accessories" placeholder="e.g. 2000" oninput="calculate()">
      </div>
    </div>
  </div>

  <!-- SUMMARY -->
  <div class="summary-card">
    <div class="summary-title">💰 Bill Summary</div>
    <div class="sline">
      <span class="sl">D54A — Chughat</span>
      <span class="sv" id="s_d54a">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">D50A — Door Frame</span>
      <span class="sv" id="s_d50a">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">D52 — Mid Bar</span>
      <span class="sv" id="s_d52">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">D61 — Plate</span>
      <span class="sv" id="s_d61">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">Aluminium Sub-Total</span>
      <span class="sv" id="s_sub">Rs. 0</span>
    </div>
    <div class="sline disc">
      <span class="sl">Discount (<span id="s_dpct">0</span>%)</span>
      <span class="sv" id="s_disc">- Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">After Discount</span>
      <span class="sv" id="s_after">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">Labour</span>
      <span class="sv" id="s_labour">Rs. 0</span>
    </div>
    <div class="sline">
      <span class="sl">Accessories</span>
      <span class="sv" id="s_access">Rs. 0</span>
    </div>
    <div class="sline grand">
      <span class="sl">GRAND TOTAL</span>
      <span class="sv" id="s_total">Rs. 0</span>
    </div>
  </div>

  <button class="btn-print" onclick="window.print()">🖨️ Print Bill</button>
  <button class="btn-reset" onclick="resetAll()">↺ Reset All</button>

</div>

<script>
  function toFt(inches) { return inches / 12; }
  function fmt(n) { return 'Rs. ' + Math.round(n).toLocaleString('en-PK'); }
  function fft(n) { return n.toFixed(2) + ' ft'; }

  function calculate() {
    var cw = parseFloat(document.getElementById('cw').value) || 0;
    var ch = parseFloat(document.getElementById('ch').value) || 0;

    var R54A = 397;
    var R50A = 490;
    var R52  = 434;
    var R61  = 514;

    // D54A: 1 top + 2 sides
    var d54a_top_ft   = toFt(cw);
    var d54a_sides_ft = toFt(ch) * 2;
    var d54a_total_ft = d54a_top_ft + d54a_sides_ft;
    var d54a_amt      = d54a_total_ft * R54A;

    // D50A: 1 top + 1 bottom + 2 sides
    var d50a_top_ft   = toFt(cw);
    var d50a_bot_ft   = toFt(cw);
    var d50a_sides_ft = toFt(ch) * 2;
    var d50a_total_ft = d50a_top_ft + d50a_bot_ft + d50a_sides_ft;
    var d50a_amt      = d50a_total_ft * R50A;

    // D52: 1 piece = width
    var d52_ft  = toFt(cw);
    var d52_amt = d52_ft * R52;

    // D61: lambai = width - 3, inner height = height - 4.5, qty = ceil(inner_h / 3.425)
    var d61_lambai  = (cw > 3) ? (cw - 3) : 0;
    var d61_inner_h = (ch > 4.5) ? (ch - 4.5) : 0;
    var d61_qty     = (d61_inner_h > 0 && d61_lambai > 0) ? Math.ceil(d61_inner_h / 3.425) : 0;
    var d61_total_ft = toFt(d61_lambai) * d61_qty;
    var d61_amt      = d61_total_ft * R61;

    // SQFT
    var sqft = toFt(cw) * toFt(ch);

    // Display D54A
    document.getElementById('d54a_top').textContent   = fft(d54a_top_ft);
    document.getElementById('d54a_sides').textContent = fft(d54a_sides_ft);
    document.getElementById('d54a_total').textContent = fft(d54a_total_ft);
    document.getElementById('d54a_amt').textContent   = fmt(d54a_amt);

    // Display D50A
    document.getElementById('d50a_top').textContent   = fft(d50a_top_ft);
    document.getElementById('d50a_bot').textContent   = fft(d50a_bot_ft);
    document.getElementById('d50a_sides').textContent = fft(d50a_sides_ft);
    document.getElementById('d50a_amt').textContent   = fmt(d50a_amt);

    // Display D52
    document.getElementById('d52_ft').textContent  = fft(d52_ft);
    document.getElementById('d52_amt').textContent = fmt(d52_amt);

    // Display D61
    document.getElementById('d61_lambai').textContent  = d61_lambai.toFixed(1) + ' in';
    document.getElementById('d61_inner').textContent   = d61_inner_h.toFixed(2) + ' in';
    document.getElementById('d61_qty').textContent     = d61_qty + ' pcs';
    document.getElementById('d61_ft_show').textContent = fft(d61_total_ft);
    document.getElementById('d61_amt').textContent     = fmt(d61_amt);

    // SQFT
    document.getElementById('sqft_val').textContent = sqft.toFixed(2) + ' sq.ft';

    // SUMMARY
    var al_sub   = d54a_amt + d50a_amt + d52_amt + d61_amt;
    var disc_pct = parseFloat(document.getElementById('discount_pct').value) || 0;
    var labour   = parseFloat(document.getElementById('labour').value) || 0;
    var access   = parseFloat(document.getElementById('accessories').value) || 0;

    var disc_amt   = al_sub * (disc_pct / 100);
    var after_disc = al_sub - disc_amt;
    var grand      = after_disc + labour + access;

    document.getElementById('s_d54a').textContent  = fmt(d54a_amt);
    document.getElementById('s_d50a').textContent  = fmt(d50a_amt);
    document.getElementById('s_d52').textContent   = fmt(d52_amt);
    document.getElementById('s_d61').textContent   = fmt(d61_amt);
    document.getElementById('s_sub').textContent   = fmt(al_sub);
    document.getElementById('s_dpct').textContent  = disc_pct;
    document.getElementById('s_disc').textContent  = '- ' + fmt(disc_amt);
    document.getElementById('s_after').textContent = fmt(after_disc);
    document.getElementById('s_labour').textContent = fmt(labour);
    document.getElementById('s_access').textContent = fmt(access);
    document.getElementById('s_total').textContent  = fmt(grand);
  }

  function resetAll() {
    document.getElementById('cw').value = '';
    document.getElementById('ch').value = '';
    document.getElementById('discount_pct').value = '';
    document.getElementById('labour').value = '';
    document.getElementById('accessories').value = '';
    calculate();
  }
</script>
</body>
</html>
